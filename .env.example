# Google Cloud / Vertex AI Runtime Configuration
USE_VERTEX_AI=true
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# Shorthand Gemini API Key (Fallback if USE_VERTEX_AI=false)
GEMINI_API_KEY=your-gemini-api-key

# OKX API Authentication (Required)
OKX_API_KEY=your-okx-api-key
OKX_SECRET_KEY=your-okx-api-secret
OKX_PASSPHRASE=your-okx-passphrase

# Trading Environment Mode: 'demo' (simulated trading, recommended) or 'live'
OKX_MODE=demo
